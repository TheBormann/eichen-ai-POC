# Copy to .env and fill in your key(s)
# You only need ONE of these — pick the model you have access to
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Leave blank for LOCAL mode
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Runner configuration
TARGET_URL=http://localhost:5173
SPEC_PATH=./specs/dashboard.md
AUTH_SESSION_PATH=./auth/session.json
HEADLESS=false
MAX_STEPS=100
REPORTS_DIR=./reports
