# Copy to .env and add your API key.
# Everything else (URL, auth, headless, max_steps) is configured in your suite file.

# Pick one:
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional — for cloud browser runs (leave blank to use local Chrome)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
